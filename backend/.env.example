# =============================================================================
# AgenticFlow — backend environment
# Copy this file to backend/.env (dev) or ./.env (Docker Compose).
# Never commit the real .env — it's gitignored project-wide.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider selection
#   anthropic_api   -> Anthropic API key (recommended, full features)
#   anthropic_cli   -> Claude Code CLI subprocess (subscription auth)
#   google_genai    -> Google Gemini API key (full features)
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic_api

# Anthropic API (official SDK)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_AGENT=claude-opus-4-6
CLAUDE_MODEL_NODE=claude-sonnet-4-5-20250929

# Anthropic CLI (Claude Code subscription)
# Path to the `claude` binary — defaults to PATH lookup.
CLAUDE_CLI_PATH=claude

# Google Gemini (google-genai SDK)
GOOGLE_API_KEY=
GEMINI_MODEL_AGENT=gemini-2.5-pro
GEMINI_MODEL_NODE=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Crypto — REQUIRED. The app refuses to start without this.
# Generate once:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store the key safely; losing it means losing access to encrypted
# `uye_kodu` tokens. Rotation procedure: SECURITY.md.
# -----------------------------------------------------------------------------
MASTER_KEY=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./agenticflow.db

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Observability  (Sprint 5)
# -----------------------------------------------------------------------------
# Root log level: DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO

# Directory for the rotating JSON log. Leave empty to disable file logging
# (stdout only — useful in containers with a log driver that already
# captures stdout).
LOG_DIR=logs

# Filename for the rotating JSON log within LOG_DIR.
LOG_FILE=agenticflow.log

# Optional Sentry DSN. Enabling also requires the `sentry` extra:
#   pip install "agenticflow-backend[sentry]"
# Empty = Sentry disabled.
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Authentication  (Sprint 6)
# -----------------------------------------------------------------------------
# Optional shared secret. When set, every non-open request must carry
#   X-Api-Key: <value>
# Open paths that always bypass the check: /, /health, /metrics, /docs,
# /redoc, /openapi.json.
#
# Leave empty for local-dev / private-network deployments, or when a
# reverse proxy already handles authentication.
API_KEY=
